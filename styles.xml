<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#07030f</item>
        <item name="colorPrimaryDark">#07030f</item>
        <item name="colorAccent">#b16eff</item>
    </style>

    <!-- Theme for launch / splash — no action bar, matches game bg -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#07030f</item>
        <item name="colorPrimaryDark">#07030f</item>
        <item name="colorAccent">#b16eff</item>
        <item name="android:windowBackground">@color/ic_launcher_background</item>
    </style>

</resources>
